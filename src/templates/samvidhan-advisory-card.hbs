<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <title>{{title}}</title>
    <style>
      /* ── Reset ── */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      body {
        margin: 0;
      }

      /* ── Page / print ── */
      @page {
        size: 250mm 170mm;
        margin: 0;
      }
      @media print {
        html,
        body {
          -webkit-print-color-adjust: exact;
          print-color-adjust: exact;
          color-adjust: exact;
        }
        .shadow-2xl {
          box-shadow: none !important;
        }
      }

      /* ── Layout ── */
      .min-h-screen {
        min-height: 100vh;
      }
      .w-full {
        width: 100%;
      }
      .h-full {
        height: 100%;
      }
      .flex {
        display: flex;
      }
      .grid {
        display: grid;
      }
      .flex-col {
        flex-direction: column;
      }
      .items-center {
        align-items: center;
      }
      .items-end {
        align-items: flex-end;
      }
      .justify-center {
        justify-content: center;
      }
      .justify-between {
        justify-content: space-between;
      }
      .relative {
        position: relative;
      }
      .absolute {
        position: absolute;
      }
      .overflow-hidden {
        overflow: hidden;
      }
      .min-w-0 {
        min-width: 0;
      }
      .shrink-0 {
        flex-shrink: 0;
      }
      .flex-1 {
        flex: 1 1 0%;
      }

      /* ── Detail row label — never wraps ── */
      .field-label {
        white-space: nowrap;
        padding-right: 12px;
        font-weight: 600;
        min-width: 0;
      }

      /* ── Sizing ── */
      .w-\[900px\] {
        width: 900px;
      }
      .h-\[560px\] {
        height: 560px;
      }
      .w-20 {
        width: 5rem;
      }
      .h-20 {
        height: 5rem;
      }
      .w-36 {
        width: 9rem;
      }
      .h-36 {
        height: 9rem;
      }
      .w-28 {
        width: 7rem;
      }
      .w-40 {
        width: 10rem;
      }
      .h-16 {
        height: 4rem;
      }
      .h-44 {
        height: 11rem;
      }
      .h-40 {
        height: 10rem;
      }
      .w-3 {
        width: 0.75rem;
      }
      .max-w-xs {
        max-width: 20rem;
      }
      .max-w-\[200px\] {
        max-width: 200px;
      }

      /* ── Position edges ── */
      .top-0 {
        top: 0;
      }
      .left-0 {
        left: 0;
      }
      .right-0 {
        right: 0;
      }
      .bottom-0 {
        bottom: 0;
      }

      /* ── Colours ── */
      .bg-neutral-100 {
        background-color: #f5f5f5;
      }
      .bg-white {
        background-color: #ffffff;
      }
      .bg-\[\#0f2c5c\] {
        background-color: #0f2c5c;
      }
      .bg-black {
        background-color: #000000;
      }
      /* profile avatar gradient */
      .profile-gradient {
        background-image: linear-gradient(to bottom right, #d4d4d4, #737373);
      }
      .text-white {
        color: #ffffff;
      }
      .text-\[\#0f2c5c\] {
        color: #0f2c5c;
      }
      .text-neutral-600 {
        color: #525252;
      }

      /* ── Typography ── */
      .font-sans {
        font-family:
          ui-sans-serif,
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          'Segoe UI',
          Roboto,
          sans-serif;
      }
      .text-4xl {
        font-size: 2.25rem;
        line-height: 2.5rem;
      }
      .text-xl {
        font-size: 1.25rem;
        line-height: 1.75rem;
      }
      .text-lg {
        font-size: 1.125rem;
        line-height: 1.75rem;
      }
      .text-base {
        font-size: 1rem;
        line-height: 1.5rem;
      }
      .text-sm {
        font-size: 0.875rem;
        line-height: 1.25rem;
      }
      .text-xs {
        font-size: 0.75rem;
        line-height: 1rem;
      }
      .font-bold {
        font-weight: 700;
      }
      .font-semibold {
        font-weight: 600;
      }
      .tracking-wide {
        letter-spacing: 0.025em;
      }
      .tracking-030em {
        letter-spacing: 0.3em;
      }
      .tracking-widest {
        letter-spacing: 0.1em;
      }
      .leading-relaxed {
        line-height: 1.625;
      }
      .text-center {
        text-align: center;
      }
      .text-right {
        text-align: right;
      }

      /* ── Spacing ── */
      .p-6 {
        padding: 1.5rem;
      }
      .px-16 {
        padding-left: 4rem;
        padding-right: 4rem;
      }
      .pt-6 {
        padding-top: 1.5rem;
      }
      .pb-6 {
        padding-bottom: 1.5rem;
      }
      .mt-10 {
        margin-top: 2.5rem;
      }
      .mt-4 {
        margin-top: 1rem;
      }
      .mt-1 {
        margin-top: 0.25rem;
      }
      .mt-05 {
        margin-top: 0.125rem;
      }
      .-mt-1 {
        margin-top: -0.25rem;
      }
      .mb-1 {
        margin-bottom: 0.25rem;
      }
      .mr-2 {
        margin-right: 0.5rem;
      }
      .gap-4 {
        gap: 1rem;
      }
      .gap-8 {
        gap: 2rem;
      }
      .space-y-2 > * + * {
        margin-top: 0.5rem;
      }
      .space-y-05 > * + * {
        margin-top: 0.125rem;
      }

      /* ── Grid ── */
      .grid-cols-2 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      /* ── Border / radius ── */
      .rounded-2xl {
        border-radius: 1rem;
      }
      .rounded-full {
        border-radius: 9999px;
      }
      .border-4 {
        border-width: 4px;
        border-style: solid;
      }
      .border-white {
        border-color: #ffffff;
      }
      .border-t {
        border-top-width: 1px;
        border-top-style: solid;
      }
      .border-white70 {
        border-color: rgba(255, 255, 255, 0.7);
      }

      /* ── Shadows ── */
      .shadow-2xl {
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
      }
      .shadow-lg {
        box-shadow:
          0 10px 15px -3px rgba(0, 0, 0, 0.1),
          0 4px 6px -4px rgba(0, 0, 0, 0.1);
      }

      /* ── Object fit / blend ── */
      .object-contain {
        object-fit: contain;
      }
      .object-cover {
        object-fit: cover;
      }
      .mix-blend-multiply {
        mix-blend-mode: multiply;
      }

      /* ── List ── */
      .list-decimal {
        list-style-type: decimal;
      }
      .list-inside {
        list-style-position: inside;
      }
    </style>
  </head>
  <body class='min-h-screen w-full flex items-center justify-center bg-neutral-100 p-6 font-sans'>

    <div class='relative w-[900px] h-[560px] bg-white rounded-2xl shadow-2xl overflow-hidden'>

      <!-- Top blue wave -->
      <div
        class='absolute top-0 left-0 right-0 h-44 bg-[#0f2c5c]'
        style='clip-path: ellipse(120% 100% at 50% 0%);'
      ></div>
      <!-- Bottom blue wave -->
      <div
        class='absolute bottom-0 left-0 right-0 h-40 bg-[#0f2c5c]'
        style='clip-path: ellipse(120% 100% at 50% 100%);'
      ></div>
      <!-- Left vertical black bar -->
      <div class='absolute left-0 top-0 bottom-0 w-3 bg-black'></div>
      <!-- Right vertical black bar -->
      <div class='absolute right-0 top-0 bottom-0 w-3 bg-black'></div>

      <!-- Header — mirrors BrandLogo header variant, scaled for card -->
      <div class='relative flex items-center justify-center gap-4 pt-6'>
        <img src='{{logoUrl}}' alt='' class='shrink-0 w-20 h-20 rounded-full object-cover' />
        <span class='min-w-0 flex-1' style='max-width:280px;'>
          <span
            class='text-white font-bold leading-snug'
            style='display:block; font-family: Georgia, "Times New Roman", serif; font-size:2.25rem;'
          >Samvidhan</span>
          <span
            class='text-white font-semibold'
            style='display:block; font-family: ui-sans-serif, system-ui, -apple-system, sans-serif; font-size:1rem; letter-spacing:0.05em; margin-top:-2px;'
          >Legal Advisory</span>
        </span>
      </div>

      <!-- Body -->
      <div class='relative grid grid-cols-2 gap-8 px-16 mt-10'>
        <!-- Left: Profile -->
        <div class='flex flex-col items-center'>
          <div
            class='w-36 h-36 rounded-full profile-gradient border-4 border-white shadow-lg flex items-center justify-center overflow-hidden'
          >
            {{#if photoUrl}}
              <img src='{{photoUrl}}' alt='{{name}}' class='w-full h-full object-cover' />
            {{else}}
              <svg viewBox='0 0 100 100' class='w-full h-full' style='color:#525252;'>
                <circle cx='50' cy='38' r='18' fill='currentColor' />
                <path d='M15 95 C 15 65, 85 65, 85 95 Z' fill='currentColor' />
              </svg>
            {{/if}}
          </div>
          <p class='mt-4 text-[#0f2c5c] font-bold text-xl'>{{name}}</p>
        </div>

        <!-- Right: Details -->
        <div class='flex flex-col justify-center space-y-2 text-[#0f2c5c] text-base mt-4'>
          <div class='flex'><span class='field-label'>Membership No</span><span
              class='mr-2'
            >:</span><span>{{memberNo}}</span></div>
          <div class='flex'><span class='field-label'>Validity Start Date</span><span
              class='mr-2'
            >:</span><span>{{memStartDate}}</span></div>
          <div class='flex'><span class='field-label'>Validity End Date</span><span
              class='mr-2'
            >:</span><span>{{memEndDate}}</span></div>
          <div class='flex'><span class='field-label'>Mob. No</span><span class='mr-2'>:</span><span
            >{{userMobileNo}}</span></div>
        </div>
      </div>

      <!-- Footer -->
      <div
        class='absolute bottom-0 left-0 right-0 flex items-end justify-between text-white'
        style='padding: 0 4rem 1.5rem;'
      >
        <!-- Terms -->
        <div style='max-width:220px;'>
          <p class='font-bold tracking-widest mb-1' style='font-size:0.65rem;'>TERM &amp; CONDITION</p>
          <ol style='margin:0; padding-left:1.1em; font-size:0.65rem; line-height:1.5;'>
            <li style='margin-bottom:2px;'>This Card Is For Identity Only.</li>
            <li style='margin-bottom:2px;'>This Card Must Be Displayed By The Holder.</li>
            <li>Please Ensure Safe Custody Of This Card And Report Loss Immediately To Issuing
              Authority.</li>
          </ol>
        </div>

        <!-- Signature -->
        <div class='flex flex-col items-center'>
          <img src='{{signatureUrl}}' alt='Signature' class='h-16 object-contain' />
          <div class='w-40 border-t border-white70 mt-1'></div>
          <p class='text-xs tracking-widest mt-1'>SIGNATURE</p>
        </div>

        <!-- Contact -->
        <div style='text-align:right; font-size:0.7rem; line-height:1.5; max-width:180px;'>
          <p class='mb-1'>&#128222; +91 915 2921 212</p>
          <p><span class='font-semibold'>Add:</span> {{address}}</p>
        </div>
      </div>

    </div>

  </body>
</html>